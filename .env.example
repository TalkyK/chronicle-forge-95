# Supabase (Vite)
# Dev local: crie um `.env.local` (não deve ser commitado).
# Produção (ex.: Lovable/Vercel/Netlify): configure essas variáveis no provedor e faça redeploy.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use uma chave publishable (sb_publishable_...) ou a anon key legacy (JWT)
VITE_SUPABASE_ANON_KEY=YOUR_KEY_HERE
